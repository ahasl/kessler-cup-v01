[gd_scene format=3]

[ext_resource type="Script" path="res://ui/quest_row.gd" id="1"]

[sub_resource type="StyleBoxFlat" id="CardBG"]
bg_color = Color(0.06, 0.08, 0.14, 0.9)
border_width_left = 3
border_color = Color(0.35, 0.82, 1, 1)
corner_radius_top_left = 3
corner_radius_top_right = 3
corner_radius_bottom_right = 3
corner_radius_bottom_left = 3
content_margin_left = 10.0
content_margin_top = 8.0
content_margin_right = 10.0
content_margin_bottom = 8.0

[node name="QuestRow" type="PanelContainer"]
script = ExtResource("1")
theme_override_styles/panel = SubResource("CardBG")

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 2

[node name="VBox" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 4

[node name="Header" type="HBoxContainer" parent="Margin/VBox"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="Tag" type="Label" parent="Margin/VBox/Header"]
layout_mode = 2
text = "SIDE"
theme_override_colors/font_color = Color(0.35, 0.82, 1, 1)
theme_override_font_sizes/font_size = 10

[node name="Title" type="Label" parent="Margin/VBox/Header"]
layout_mode = 2
size_flags_horizontal = 3
text = "Quest Title"
theme_override_colors/font_color = Color(0.88, 0.92, 1, 1)
theme_override_font_sizes/font_size = 13

[node name="Check" type="Label" parent="Margin/VBox/Header"]
visible = false
layout_mode = 2
text = "✓"
theme_override_colors/font_color = Color(0.38, 0.85, 0.55, 1)
theme_override_font_sizes/font_size = 13

[node name="Desc" type="Label" parent="Margin/VBox"]
layout_mode = 2
text = "desc"
autowrap_mode = 3
theme_override_colors/font_color = Color(0.55, 0.6, 0.7, 1)
theme_override_font_sizes/font_size = 11
